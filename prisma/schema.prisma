generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Player {
  id        String   @id @default(cuid())
  name      String
  emoji     String   @default("🏓")
  rating    Float    @default(1000) // legacy, kept for backwards compat
  wins      Int      @default(0)
  losses    Int      @default(0)
  createdAt DateTime @default(now())

  // Global rating (from cross-club matches)
  globalRating           Float? // null = not yet established
  globalRatingConfidence Int    @default(0) // 0=none, 1-3=estimated, 4+=direct
  globalWins             Int    @default(0)
  globalLosses           Int    @default(0)

  // DUPR
  duprId     String? // DUPR player ID
  duprRating Float? // synced from DUPR

  // Auth
  email            String? @unique
  passwordHash     String?
  role             String  @default("user") // "admin" | "user"
  status           String  @default("active") // "active" | "voided"
  canCreateLeagues Boolean @default(false) // granted by app admin
  canCreateClubs   Boolean @default(false) // granted by app admin
  inviteToken      String? @unique // for claim-account flow
  resetToken       String? @unique // for password reset flow

  // Profile
  gender   String? // "M" | "F"
  phone    String? // WhatsApp number
  photoUrl String?
  /// ISO 3166-1 alpha-2 country code (e.g. "PT", "ES"). Self-set on
  /// profile; used as a coarse server-side filter on the players list.
  country  String?

  eventPlayers                 EventPlayer[]
  matchPlayers                 MatchPlayer[]
  createdEvents                Event[]                      @relation("createdEvents")
  eventHelpers                 EventHelper[]
  pairsAsPlayer1               EventPair[]                  @relation("pairPlayer1")
  pairsAsPlayer2               EventPair[]                  @relation("pairPlayer2")
  pairLocksAsA                 EventPairLock[]              @relation("pairLockA")
  pairLocksAsB                 EventPairLock[]              @relation("pairLockB")
  clubMembers                  ClubMember[]
  clubRatings                  ClubPlayerRating[]
  createdClubs                 Club[]                       @relation("createdClubs")
  clubInvites                  ClubInvite[]                 @relation("ClubInviteCreator")
  clubJoinRequests             ClubJoinRequest[]
  clubPosts                    ClubPost[]
  clubComments                 ClubComment[]
  scoredMatches                Match[]                      @relation("matchScorer")
  leagueTeamPlayers            LeagueTeamPlayer[]
  leagueCaptain                LeagueTeam[]                 @relation("teamCaptain")
  leagueViceCaptain            LeagueTeam[]                 @relation("teamViceCaptain")
  createdLeagues               League[]                     @relation("leagueCreator")
  deputyLeagues                League[]                     @relation("leagueDeputy")
  leagueHelpers                LeagueHelper[]
  leagueGamePlayers            LeagueGamePlayer[]
  uploadedLeagueDocuments      LeagueDocument[]             @relation("leagueDocumentUploader")
  leagueAssistantQueries       LeagueAssistantQuery[]       @relation("leagueAssistantQueryAsker")
  leagueParticipationRequests  LeagueParticipationRequest[] @relation("playerLeagueRequests")
  leagueParticipationResponses LeagueParticipationRequest[] @relation("leagueRequestResponder")
  // Audit
  addedById     String?
  addedBy       Player?  @relation("playerAddedBy", fields: [addedById], references: [id])
  addedPlayers  Player[] @relation("playerAddedBy")
  createdMatches      Match[]       @relation("matchCreator")
  createdLeagueGames  LeagueGame[]  @relation("leagueGameCreator")
}

model Club {
  id                  String   @id @default(cuid())
  name                String
  shortName           String? // ≤20 chars, used in pills/badges; falls back to name[:20]
  emoji               String   @default("🏟️")
  logoUrl             String?
  coverUrl            String?
  description         String?
  city                String?
  country             String?
  status              String   @default("active") // "draft" | "active" | "closed"
  ratingOffset        Float? // club rating - global rating offset (calculated)
  ratingBridgePlayers Int      @default(0) // how many players have global ratings
  createdAt           DateTime @default(now())

  createdById String?
  createdBy   Player? @relation("createdClubs", fields: [createdById], references: [id])

  members        ClubMember[]
  playerRatings  ClubPlayerRating[]
  events         Event[]
  whatsappGroups WhatsAppGroup[]
  posts          ClubPost[]
  locations      ClubLocation[]
  invites        ClubInvite[]
  joinRequests   ClubJoinRequest[]
  leagueTeams    LeagueTeam[]
  leagues        League[]           @relation("clubLeagues")
}

model ClubPlayerRating {
  id       String @id @default(cuid())
  clubId   String
  playerId String
  rating   Float  @default(1000)
  wins     Int    @default(0)
  losses   Int    @default(0)

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId])
}

model ClubLocation {
  id            String  @id @default(cuid())
  clubId        String
  name          String
  googleMapsUrl String?
  city          String?
  country       String?
  /// Number of courts available at this location. Used as the default (and
  /// cap) for events created at this location.
  numCourts     Int     @default(2)

  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  events Event[]
}

model ClubMember {
  id       String @id @default(cuid())
  clubId   String
  playerId String
  role     String @default("member") // "owner" | "admin" | "member"

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId])
  @@index([playerId])
}

model ClubJoinRequest {
  id        String   @id @default(cuid())
  clubId    String
  playerId  String
  message   String?
  status    String   @default("pending") // "pending" | "accepted" | "declined"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId])
}

model ClubInvite {
  id        String    @id @default(cuid())
  clubId    String
  token     String    @unique @default(cuid())
  createdBy String
  expiresAt DateTime?
  usedCount Int       @default(0)
  maxUses   Int? // null = unlimited
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  club    Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator Player @relation("ClubInviteCreator", fields: [createdBy], references: [id])
}

model Event {
  id         String    @id @default(cuid())
  name       String
  date       DateTime  @default(now())
  endDate    DateTime?
  // Stored: setup | open | closed.
  //   setup  — being shaped. For LEAGUE events: only league admin can
  //            see; auto-flips to "open" when the parent Round goes
  //            Active. For STANDALONE events: creator-only.
  //   open   — registration accepting sign-ups
  //   closed — registration locked (no more sign-ups). Nothing to do
  //            with lineups — that's tracked on Event.lineupTotalLocked
  //            + leagueTeams[].lineupReady.
  // Legacy values still tolerated on read: visible, completed, draft, active.
  status     String    @default("setup")
  /// Cross-team lineup reveal latch. Flips to true the moment BOTH
  /// teams' `LeagueEventTeam.lineupReady` become true. Never resets to
  /// false. After it's true, lineup-mutation endpoints require BOTH
  /// teams to also have lineupReady=false (mutual unlock) — neither
  /// team can stealth-edit after seeing the opponent's lineup.
  lineupTotalLocked Boolean @default(false)
  numCourts  Int       @default(2)
  openSignup Boolean   @default(true) // kept for backwards compat
  visibility String    @default("visible") // kept for backwards compat
  /// Per-event override of the round (or league) default match duration
  /// used by the auto-schedule. Null = inherit from the round.
  matchDurationMin Int?
  /// Per-court start times for the auto-schedule, keyed by court number
  /// as a string: { "1": "2026-05-17T13:00:00.000Z", "2": "…" }. Empty
  /// or missing keys → the auto-schedule won't place matches on that
  /// court until the host captain sets a start. The arrow button in
  /// the UI copies Court 1's value to all other courts.
  courtStartTimes Json?

  // Speaker host
  speakerUserId       String? // player ID of the device acting as speaker
  speakerUserName     String? // display name
  pendingAnnouncement String? // text to speak, cleared after played

  createdAt DateTime @default(now())

  createdById String?
  createdBy   Player? @relation("createdEvents", fields: [createdById], references: [id])

  clubId     String?
  club       Club?         @relation(fields: [clubId], references: [id])
  locationId String?
  location   ClubLocation? @relation(fields: [locationId], references: [id])

  // Multi-week competition: sessions link to parent
  parentEventId String?
  parentEvent   Event?  @relation("eventSessions", fields: [parentEventId], references: [id])
  sessions      Event[] @relation("eventSessions")

  // Linked "social side" event. For a league match-day event the organizer
  // can opt-in to running a parallel social event — same date, same club —
  // for casual play among everyone who isn't strictly attending-only.
  // Players never sign up directly to the social event; sign-ups happen
  // on the league event and are mirrored here based on intent. Set on
  // the SOCIAL event, pointing at its league parent.
  socialOfEventId String?
  socialOf        Event?  @relation("eventSocial", fields: [socialOfEventId], references: [id])
  socialEvents    Event[] @relation("eventSocial") // 0 or 1 in practice

  classes        EventClass[]
  players        EventPlayer[]
  pairs          EventPair[]
  pairLocks      EventPairLock[]
  matches        Match[]
  helpers        EventHelper[]
  whatsappGroups EventWhatsAppGroup[]

  // League-attached fields. When `roundId` is set, the event represents a
  // specific match-day for two league teams. Otherwise the event is a
  // standalone social/competition event.
  roundId     String?
  round       LeagueRound?      @relation(fields: [roundId], references: [id])
  hostTeamId  String?
  hostTeam    LeagueTeam?       @relation("eventHostTeam", fields: [hostTeamId], references: [id])
  leagueTeams LeagueEventTeam[]
  leagueGames LeagueGame[]

  @@index([clubId])
  @@index([status])
  @@index([date])
  @@index([roundId])
}

model EventClass {
  id        String  @id @default(cuid())
  eventId   String
  name      String  @default("Open")
  isDefault Boolean @default(true) // the auto-created class

  // Dimensions
  format   String @default("doubles") // doubles, singles
  gender   String @default("open") // male, female, mix, open
  ageGroup String @default("open") // open, 18+, 50+, 60+, custom
  ageMin   Int?
  ageMax   Int?
  skillMin Float? // DUPR min (e.g. 3.5)
  skillMax Float? // DUPR max (e.g. 4.0)

  // Format settings
  scoringFormat   String  @default("1x11") // e.g. "1x11", "3x11", "1xR15", "3xR21"
  winBy           String  @default("2") // "1", "2", "cap13", "cap15", "cap17", "cap18", "cap23", "cap25"
  timedMinutes    Int?
  /// Max minutes a match in this class may run before being auto-finalized.
  /// Behaviour combines with `scoringEnforced`:
  ///   - maxMinutes null: scoring rules always apply, no timer.
  ///   - maxMinutes set + scoringEnforced=true: scoring rules apply normally
  ///     AND the timer acts as a hard cap (the match auto-ends if neither
  ///     team has reached the target by then, accepting any score).
  ///   - maxMinutes set + scoringEnforced=false: timer-only mode; players
  ///     submit whatever final score they had when the clock ran out and
  ///     target/win-by validation is skipped.
  maxMinutes      Int?
  /// When false AND maxMinutes is set, the score picker accepts any number
  /// pair (timer-only). When true (default), normal target/win-by rules
  /// apply and the match ends as soon as a team wins (timer is a safety
  /// cap, not the primary trigger).
  scoringEnforced Boolean @default(true)
  pairingMode     String  @default("random")
  /// New unified pairing settings (v2 model). JSON shape matches
  /// PairingSettings from src/lib/solver/types.ts. When present, the solver
  /// uses this instead of the legacy pairingMode + prio* booleans.
  pairingSettings Json?
  playMode        String  @default("round_based") // "round_based" | "continuous"
  prioSpeed       Boolean @default(true)
  prioFairness    Boolean @default(true)
  prioSkill       Boolean @default(false)
  prioVariety     Boolean @default(false)
  rankingMode     String  @default("ranked")
  minPlayers      Int?
  maxPlayers      Int?

  // Below-min action
  belowMinAction   String? // "cancel" | "merge" | "tbd"
  mergeWithClassId String? // class to merge with if belowMinAction = "merge"

  // Cross-class elimination merge
  upperBracketMergeClassId String? // merge upper bracket with this class's lower bracket
  lowerBracketMergeClassId String? // merge lower bracket with this class's upper bracket

  // Competition
  competitionMode   String? // null | "groups_elimination"
  competitionConfig Json?
  competitionPhase  String? // "groups" | "bracket_upper" | "bracket_lower" | "completed"

  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  players   EventPlayer[]
  pairs     EventPair[]
  pairLocks EventPairLock[]
  matches   Match[]

  @@index([eventId])
}

model Notification {
  id        String   @id @default(cuid())
  playerId  String
  type      String // "pair_request" | "pair_accepted" | "match_ready" | "event_invite"
  title     String
  body      String?
  linkUrl   String? // where to navigate when tapped
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PairRequest {
  id          String   @id @default(cuid())
  eventId     String
  classId     String
  requesterId String // who asked
  requestedId String // who they asked
  status      String   @default("pending") // "pending" | "accepted" | "declined" | "cancelled"
  createdAt   DateTime @default(now())

  @@unique([eventId, classId, requesterId])
}

model EventPlayer {
  id                String   @id @default(cuid())
  eventId           String
  classId           String?
  playerId          String
  status            String   @default("registered")
  /// Effective skill level used by the solver. L1–L5. Equals autoSkillLevel
  /// unless an admin has overridden it. See src/lib/solver/skillAssign.ts.
  skillLevel        Int?
  /// Auto-assigned skill level from DUPR/rating at the time of add or
  /// last recalculate. Preserved across overrides so admins can see the gap.
  autoSkillLevel    Int?
  /// Match count offset for late joiners — stores the average match count
  /// at the time of check-in so the solver treats them fairly.
  matchCountOffset  Int      @default(0)
  /// Per-category preferences for league-attached events. Shape:
  ///   { [categoryId]: { level: "prefer"|"ok"|"no", note?: string } }
  /// Mirrors LeagueParticipationRequest.preferences. Null/undefined for
  /// standalone events.
  signupPreferences Json?
  joinedAt          DateTime @default(now())

  event  Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class  EventClass? @relation(fields: [classId], references: [id], onDelete: Cascade)
  player Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId, classId])
  @@index([playerId])
}

/// Manual pair lock — two players who MUST partner on every round they
/// play. Used for tournament practice pairs, mentor-mentee, family etc.
model EventPairLock {
  id        String   @id @default(cuid())
  eventId   String
  classId   String?
  playerAId String
  playerBId String
  note      String? // optional reason, e.g. "practicing for tournament"
  createdAt DateTime @default(now())

  event   Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class   EventClass? @relation(fields: [classId], references: [id], onDelete: Cascade)
  playerA Player      @relation("pairLockA", fields: [playerAId], references: [id], onDelete: Cascade)
  playerB Player      @relation("pairLockB", fields: [playerBId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerAId, playerBId])
  @@index([eventId])
}

model EventPair {
  id         String  @id @default(cuid())
  eventId    String
  classId    String?
  player1Id  String
  player2Id  String
  groupLabel String?
  seed       Int?

  event   Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class   EventClass? @relation(fields: [classId], references: [id], onDelete: Cascade)
  player1 Player      @relation("pairPlayer1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2 Player      @relation("pairPlayer2", fields: [player2Id], references: [id], onDelete: Cascade)

  @@unique([eventId, player1Id, player2Id])
}

model EventHelper {
  id       String @id @default(cuid())
  eventId  String
  playerId String

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

model Match {
  id             String  @id @default(cuid())
  eventId        String
  classId        String?
  courtNum       Int
  round          Int
  status         String  @default("pending")
  rankingMode    String  @default("ranked")
  scoreConfirmed Boolean @default(false)
  team1Confirmed Boolean @default(false)
  team2Confirmed Boolean @default(false)
  confirmedById  String? // who did final/manager confirmation
  eloChange      Float   @default(0)

  // Competition metadata
  groupLabel      String?
  bracketStage    String?
  bracketPosition Int?
  matchFormat     String?
  sessionId       String? // which session this match is scheduled in
  isCrossClub     Boolean @default(false) // players from different clubs
  scorerId        String? // player assigned as scorer/judge

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  createdById String? // audit — null on rows created before audit was added

  event      Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class      EventClass?   @relation(fields: [classId], references: [id], onDelete: Cascade)
  scorer     Player?       @relation("matchScorer", fields: [scorerId], references: [id])
  createdBy  Player?       @relation("matchCreator", fields: [createdById], references: [id])
  players    MatchPlayer[]
  leagueGame LeagueGame?

  @@index([eventId])
  @@index([status])
}

model CompetitionResult {
  id       String  @id @default(cuid())
  eventId  String
  classId  String
  playerId String
  pairId   String?

  // Group stage results
  groupLabel     String?
  groupPosition  Int? // 1st, 2nd, 3rd in group
  groupWins      Int     @default(0)
  groupLosses    Int     @default(0)
  groupPointDiff Int     @default(0)

  // Elimination results
  bracketLevel   String? // "upper" | "lower"
  bracketReached String? // "r16", "qf", "sf", "f", "winner"
  finalPlacement Int? // 1st, 2nd, 3rd, etc.

  createdAt DateTime @default(now())

  @@unique([eventId, classId, playerId])
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  team     Int // 1 or 2
  score    Int    @default(0)

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([playerId])
}

model WhatsAppGroup {
  id        String   @id @default(cuid())
  name      String // e.g. "Tuesday Crew", "Mixed Doubles"
  createdAt DateTime @default(now())

  clubId String?
  club   Club?   @relation(fields: [clubId], references: [id])

  events EventWhatsAppGroup[]
}

model EventWhatsAppGroup {
  id              String @id @default(cuid())
  eventId         String
  whatsappGroupId String

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  whatsappGroup WhatsAppGroup @relation(fields: [whatsappGroupId], references: [id], onDelete: Cascade)

  @@unique([eventId, whatsappGroupId])
}

model ClubPost {
  id        String   @id @default(cuid())
  clubId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  club     Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author   Player        @relation(fields: [authorId], references: [id])
  comments ClubComment[]
}

model ClubComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   ClubPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author Player   @relation(fields: [authorId], references: [id])
}

// ── League / Season ──

model League {
  id           String   @id @default(cuid())
  name         String
  shortName    String? // ≤10 chars, used in pills/badges/headers; falls back to name when null
  description  String?
  season       String? // "2025", "Spring 2026"
  // Status drives visibility:
  //   setup        — only organizers see the league
  //   registration — public; players can self-sign-up
  //   forming      — public; self-signup CLOSED; captains/admins still add players
  //   active       — public; rosters are visible to everyone (teams locked)
  //   complete     — public; archived
  // Stored: setup | open | closed | active | complete.
  //   open   — registration accepted (display: "Registration open")
  //   closed — registration stopped, captains finalising rosters (display: "Registration closed")
  // Legacy values still tolerated on read: registration → open, forming → closed.
  status       String   @default("setup")
  config       Json? // { maxRoster, bestOfN, maxPointsPerMatchDay, scoringRules }
  rulesPdfUrl  String? // optional PDF (rules, regulations, schedule, etc.)
  rulesPdfName String? // original filename, for display
  visibility   String   @default("public") // "public" | "participants"
  clubId       String? // Organizing club (required at creation; optional for legacy rows)
  createdById  String? // League Director
  deputyId     String? // Deputy Director
  createdAt    DateTime @default(now())
  /// Default match duration in minutes, used by the auto-schedule.
  /// Rounds can override this; events inherit (with their own optional
  /// override); categories can override further. Always inclusive of
  /// warmup — durations measure start-to-next-start on the same court.
  matchDurationMin Int? @default(45)

  club                  Club?                        @relation("clubLeagues", fields: [clubId], references: [id])
  createdBy             Player?                      @relation("leagueCreator", fields: [createdById], references: [id])
  deputy                Player?                      @relation("leagueDeputy", fields: [deputyId], references: [id])
  teams                 LeagueTeam[]
  rounds                LeagueRound[]
  categories            LeagueCategory[]
  helpers               LeagueHelper[]
  documents             LeagueDocument[]
  assistantQueries      LeagueAssistantQuery[]
  participationRequests LeagueParticipationRequest[]

  @@index([clubId])
}

model LeagueHelper {
  id       String @id @default(cuid())
  leagueId String
  playerId String

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([leagueId, playerId])
}

model LeagueTeam {
  id               String    @id @default(cuid())
  leagueId         String
  clubId           String? // optional link to Club
  name             String
  slogan           String?
  logoUrl          String?
  photoUrl         String? // team group photo
  captainId        String? // "Team Leader"
  viceCaptainId    String? // "Deputy"
  rosterLocked     Boolean   @default(false)
  rosterLockedAt   DateTime?
  rosterLockedById String?

  league                League                       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  club                  Club?                        @relation(fields: [clubId], references: [id])
  captain               Player?                      @relation("teamCaptain", fields: [captainId], references: [id])
  viceCaptain           Player?                      @relation("teamViceCaptain", fields: [viceCaptainId], references: [id])
  players               LeagueTeamPlayer[]
  eventTeams            LeagueEventTeam[]
  hostedEvents          Event[]                      @relation("eventHostTeam")
  gamesAsTeam1          LeagueGame[]                 @relation("gameTeam1")
  gamesAsTeam2          LeagueGame[]                 @relation("gameTeam2")
  gamesWon              LeagueGame[]                 @relation("gameWinner")
  participationRequests LeagueParticipationRequest[] @relation("preferredTeamRequests")
}

model LeagueTeamPlayer {
  id       String   @id @default(cuid())
  teamId   String
  playerId String
  joinedAt DateTime @default(now())

  team   LeagueTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player     @relation(fields: [playerId], references: [id])

  @@unique([teamId, playerId])
}

model LeagueCategory {
  id            String @id @default(cuid())
  leagueId      String
  name          String // "Men's Doubles", "Women's Doubles", "Mixed Doubles", "Singles"
  format        String @default("doubles") // "doubles" or "singles"
  gender        String @default("open") // "male", "female", "mix", "open"
  ageGroup      String @default("open") // "open", "18+", "35+", "50+", "55+", "60+", "65+", "70+"
  skillMin      Float? // DUPR min (e.g. 3.0)
  skillMax      Float? // DUPR max (e.g. 4.0)
  scoringFormat String @default("3x11") // e.g. "1x11", "3x11", "1xR15"
  winBy         String @default("2")
  status        String @default("active") // "draft" | "active"
  sortOrder     Int    @default(0)
  maxPerEvent   Int? // max number of slots in this category per match-day event
  /// Per-category override of the inherited (event → round → league)
  /// default match duration. Null = use inherited default.
  matchDurationMin Int?

  league League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  games  LeagueGame[]
}

model LeagueRound {
  id                 String    @id @default(cuid())
  leagueId           String
  roundNumber        Int
  name               String? // "Jornada 1", "Grande Final"
  // Replaces the old single suggestedDate. Rounds are time windows. Events
  // attached to a round are expected to fall inside [startDate, endDate];
  // this is treated as a soft hint, not a hard constraint.
  startDate          DateTime?
  endDate            DateTime?
  // Optional per-round overrides. When set, take precedence over the league
  // defaults at read time (e.g. resolveRoundConfig(round, league)).
  configOverride     Json?
  categoriesOverride Json?
  // Stored status:
  //   setup  — admin is still configuring; hidden from non-managers
  //   active — published; the lifecycle (scheduled/in-progress/completed)
  //            is then derived from startDate/endDate at display time.
  status             String    @default("setup") // setup | active (legacy: "scheduled" still recognized as active)
  /// Per-round override of the league's default match duration. Null →
  /// inherit from the league. Events under this round inherit this
  /// value (and can themselves override).
  matchDurationMin   Int?

  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  events Event[]
}

// ── League event team participation ──
// Each league-attached Event has 1-2 LeagueEventTeam rows recording the
// teams that play, plus their cached match-day points.
model LeagueEventTeam {
  id      String @id @default(cuid())
  eventId String
  teamId  String
  points  Int    @default(0)
  // Captain marks "Done picking" once their lineup is final. The opposing
  // team's player assignments stay hidden until BOTH teams set this true,
  // mirroring the old reveal-on-submit flow but per match-day.
  lineupReady     Boolean   @default(false)
  lineupReadyAt   DateTime?
  lineupReadyById String?

  event Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  team  LeagueTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([eventId, teamId])
  @@index([eventId])
}

model LeagueGame {
  id         String  @id @default(cuid())
  eventId    String
  categoryId String
  // 1-based slot within (event, category). Lazy-created when the first
  // team ticks the checkbox; deleted when neither team wants it any more.
  slotNumber Int     @default(1)
  matchId    String? @unique // link to existing Match for scoring
  team1Id    String
  team2Id    String
  winnerId   String? // set when match completes
  // Match kind. Exactly one "principal" per category if any league games
  // exist (server-enforced). "league" counts for event points + category
  // standings. "extra" is recorded but doesn't count for either.
  kind       String  @default("league") // "principal" | "league" | "extra"
  // Per-team intent flags. Match exists when at least one is true; deleted
  // when both go false. A team can't unset its flag once it has assigned
  // players (LeagueGamePlayer rows) for this game.
  team1Wants Boolean @default(false)
  team2Wants Boolean @default(false)
  // Schedule (set by the home team's captain or a league organizer):
  //   scheduledAt — wall-clock start time for this match
  //   courtNum    — court assignment within the venue
  // Both optional; the round-event matches view sorts by them.
  scheduledAt DateTime?
  courtNum    Int?
  // Manual ordering within a court column for the Matches-tab schedule.
  // Drag-and-drop writes integers per column; lower = earlier in the
  // list. Sort uses (displayOrder asc NULLS LAST, then scheduledAt asc,
  // then category/slot for stability).
  displayOrder Int?
  /// True when the operator manually set scheduledAt for this match
  /// (e.g. inserted a lunch break or fixed a key match's time). The
  /// auto-schedule preserves anchored times and chains subsequent
  /// matches forward from each anchor. False = auto-derived.
  scheduleAnchored Boolean @default(false)
  createdById String? // audit — captain or organizer who first ticked this slot

  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category    LeagueCategory     @relation(fields: [categoryId], references: [id])
  match       Match?             @relation(fields: [matchId], references: [id])
  team1       LeagueTeam         @relation("gameTeam1", fields: [team1Id], references: [id])
  team2       LeagueTeam         @relation("gameTeam2", fields: [team2Id], references: [id])
  winner      LeagueTeam?        @relation("gameWinner", fields: [winnerId], references: [id])
  createdBy   Player?            @relation("leagueGameCreator", fields: [createdById], references: [id])
  gamePlayers LeagueGamePlayer[]

  @@unique([eventId, categoryId, slotNumber])
  @@index([eventId])
}

model LeagueGamePlayer {
  id           String @id @default(cuid())
  leagueGameId String
  playerId     String
  // Side of the game this player belongs to (1 = team1, 2 = team2).
  // Optional for back-compat with rows created before this field existed;
  // when null, the client falls back to roster-based heuristics.
  team         Int?

  leagueGame LeagueGame @relation(fields: [leagueGameId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id])

  @@unique([leagueGameId, playerId])
}

// ── League participation requests ──
// A signed-up player that captains/director can accept onto a team.
model LeagueParticipationRequest {
  id              String    @id @default(cuid())
  leagueId        String
  playerId        String
  status          String    @default("pending") // pending | accepted | declined | withdrawn
  preferredTeamId String?
  preferences     Json? // { [categoryId]: { level: "prefer"|"ok"|"no", note?: string } }
  respondedById   String?
  respondedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  league        League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  player        Player      @relation("playerLeagueRequests", fields: [playerId], references: [id])
  preferredTeam LeagueTeam? @relation("preferredTeamRequests", fields: [preferredTeamId], references: [id])
  respondedBy   Player?     @relation("leagueRequestResponder", fields: [respondedById], references: [id])

  @@unique([leagueId, playerId])
  @@index([leagueId])
}

// LeagueLineup / LeagueLineupSlot: removed. The new model lazy-creates a
// LeagueGame row per (event, category, slotNumber) when a team ticks the
// "we want to play this slot" checkbox; LeagueGamePlayer holds each team's
// players for that game. No separate lineup table needed.

// ── League documents (rules, schedule, posters, etc.) ──
// Chat-log row for the jabberBrain League Assistant. One row per
// user turn (question + assistant answer). Logged to a database so
// league organizers and app admins can review what players are asking
// about the rules. Anonymous users supported — playerId is null then.
model LeagueAssistantQuery {
  id             String   @id @default(cuid())
  leagueId       String
  conversationId String // groups turns from the same chat session
  playerId       String? // null for anonymous askers
  question       String   @db.Text
  answer         String   @db.Text
  // Soft PII flag: true if any email/phone-like pattern was redacted
  // before persistence. Helps audit how often PII shows up in queries.
  piiScrubbed    Boolean  @default(false)
  // Anthropic usage telemetry — input/output/cache token counts so we
  // can sanity-check spend per league. Zero on errored requests.
  tokensInput       Int     @default(0)
  tokensOutput      Int     @default(0)
  tokensCacheRead   Int     @default(0)
  tokensCacheCreate Int     @default(0)
  // Filled if the model returned an error (e.g. quota) or the request
  // never reached the model. Null on successful answers.
  errorMessage   String?
  createdAt      DateTime @default(now())

  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  player Player? @relation("leagueAssistantQueryAsker", fields: [playerId], references: [id], onDelete: SetNull)

  @@index([leagueId, createdAt])
  @@index([conversationId])
}

model LeagueDocument {
  id           String   @id @default(cuid())
  leagueId     String
  url          String
  name         String // original filename
  mimeType     String
  sizeBytes    Int
  uploadedById String?
  uploadedAt   DateTime @default(now())
  // When true and mimeType is application/pdf, this document is fed to
  // the jabberBrain League Assistant. PDFs only — images are not
  // supported by the assistant. Default true so newly-uploaded rules
  // PDFs are queryable out of the box.
  includeInAssistant Boolean @default(true)
  // When true, this document is listed in the user-facing Documents
  // section of the league overview. Independent from includeInAssistant
  // so organizers can keep an internal-only doc for the AI while
  // showing a cleaner public version to players, or vice versa.
  showToUsers Boolean @default(true)

  league     League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  uploadedBy Player? @relation("leagueDocumentUploader", fields: [uploadedById], references: [id])

  @@index([leagueId])
}
