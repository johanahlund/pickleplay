generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Player {
  id           String   @id @default(cuid())
  name         String
  emoji        String   @default("🏓")
  rating       Float    @default(1000)  // legacy, kept for backwards compat
  wins         Int      @default(0)
  losses       Int      @default(0)
  createdAt    DateTime @default(now())

  // Global rating (from cross-club matches)
  globalRating           Float?   // null = not yet established
  globalRatingConfidence Int      @default(0) // 0=none, 1-3=estimated, 4+=direct
  globalWins             Int      @default(0)
  globalLosses           Int      @default(0)

  // DUPR
  duprId       String?  // DUPR player ID
  duprRating   Float?   // synced from DUPR

  // Auth
  email        String?  @unique
  passwordHash String?
  role         String   @default("user") // "admin" | "user"
  status       String   @default("active") // "active" | "voided"
  inviteToken  String?  @unique // for claim-account flow
  resetToken   String?  @unique // for password reset flow

  // Profile
  gender       String?  // "M" | "F"
  phone        String?  // WhatsApp number
  photoUrl     String?

  eventPlayers  EventPlayer[]
  matchPlayers  MatchPlayer[]
  createdEvents Event[]       @relation("createdEvents")
  eventHelpers  EventHelper[]
  pairsAsPlayer1 EventPair[]  @relation("pairPlayer1")
  pairsAsPlayer2 EventPair[]  @relation("pairPlayer2")
  clubMembers   ClubMember[]
  clubRatings   ClubPlayerRating[]
  createdClubs  Club[]        @relation("createdClubs")
  clubPosts     ClubPost[]
  clubComments  ClubComment[]
}

model Club {
  id          String   @id @default(cuid())
  name        String
  emoji       String   @default("🏓")
  description String?
  ratingOffset Float?  // club rating - global rating offset (calculated)
  ratingBridgePlayers Int @default(0) // how many players have global ratings
  createdAt   DateTime @default(now())

  createdById String?
  createdBy   Player?  @relation("createdClubs", fields: [createdById], references: [id])

  members        ClubMember[]
  playerRatings  ClubPlayerRating[]
  events         Event[]
  whatsappGroups WhatsAppGroup[]
  posts          ClubPost[]
  locations      ClubLocation[]
}

model ClubPlayerRating {
  id       String @id @default(cuid())
  clubId   String
  playerId String
  rating   Float  @default(1000)
  wins     Int    @default(0)
  losses   Int    @default(0)

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId])
}

model ClubLocation {
  id            String @id @default(cuid())
  clubId        String
  name          String
  googleMapsUrl String?
  city          String?
  country       String?

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ClubMember {
  id       String @id @default(cuid())
  clubId   String
  playerId String
  role     String @default("member") // "owner" | "admin" | "member"

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId])
}

model Event {
  id           String   @id @default(cuid())
  name         String
  date         DateTime @default(now())
  endDate      DateTime?
  status       String   @default("draft") // draft, visible, open, closed, active, completed
  numCourts    Int      @default(2)
  openSignup   Boolean  @default(true)  // kept for backwards compat
  visibility   String   @default("visible") // kept for backwards compat

  // Speaker host
  speakerUserId   String?  // player ID of the device acting as speaker
  speakerUserName String?  // display name
  pendingAnnouncement String? // text to speak, cleared after played

  createdAt    DateTime @default(now())

  createdById  String?
  createdBy    Player?  @relation("createdEvents", fields: [createdById], references: [id])

  clubId       String?
  club         Club?    @relation(fields: [clubId], references: [id])

  // Multi-week competition: sessions link to parent
  parentEventId String?
  parentEvent   Event?   @relation("eventSessions", fields: [parentEventId], references: [id])
  sessions      Event[]  @relation("eventSessions")

  classes        EventClass[]
  players        EventPlayer[]
  pairs          EventPair[]
  matches        Match[]
  helpers        EventHelper[]
  whatsappGroups EventWhatsAppGroup[]
}

model EventClass {
  id          String @id @default(cuid())
  eventId     String
  name        String @default("Open")
  isDefault   Boolean @default(true) // the auto-created class

  // Dimensions
  format      String  @default("doubles") // doubles, singles
  gender      String  @default("open")    // male, female, mix, open
  ageGroup    String  @default("open")    // open, 18+, 50+, 60+, custom
  ageMin      Int?
  ageMax      Int?
  skillMin    Float?  // DUPR min (e.g. 3.5)
  skillMax    Float?  // DUPR max (e.g. 4.0)

  // Format settings
  numSets      Int      @default(1)
  scoringType  String   @default("normal_11")
  timedMinutes Int?
  pairingMode  String   @default("random")
  playMode     String   @default("round_based") // "round_based" | "continuous"
  prioSpeed    Boolean  @default(true)
  prioFairness Boolean  @default(true)
  prioSkill    Boolean  @default(false)
  rankingMode  String   @default("ranked")
  minPlayers   Int?
  maxPlayers   Int?

  // Below-min action
  belowMinAction    String?  // "cancel" | "merge" | "tbd"
  mergeWithClassId  String?  // class to merge with if belowMinAction = "merge"

  // Cross-class elimination merge
  upperBracketMergeClassId  String?  // merge upper bracket with this class's lower bracket
  lowerBracketMergeClassId  String?  // merge lower bracket with this class's upper bracket

  // Competition
  competitionMode   String?  // null | "groups_elimination"
  competitionConfig Json?
  competitionPhase  String?  // "groups" | "bracket_upper" | "bracket_lower" | "completed"

  event    Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  players  EventPlayer[]
  pairs    EventPair[]
  matches  Match[]
}

model EventPlayer {
  id         String   @id @default(cuid())
  eventId    String
  classId    String?
  playerId   String
  status     String   @default("registered")
  skillLevel Int?
  joinedAt   DateTime @default(now())

  event  Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class  EventClass? @relation(fields: [classId], references: [id], onDelete: Cascade)
  player Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId, classId])
}

model EventPair {
  id        String @id @default(cuid())
  eventId   String
  classId   String?
  player1Id String
  player2Id String
  groupLabel String?
  seed       Int?

  event   Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class   EventClass? @relation(fields: [classId], references: [id], onDelete: Cascade)
  player1 Player      @relation("pairPlayer1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2 Player      @relation("pairPlayer2", fields: [player2Id], references: [id], onDelete: Cascade)

  @@unique([eventId, player1Id, player2Id])
}

model EventHelper {
  id       String @id @default(cuid())
  eventId  String
  playerId String

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

model Match {
  id        String   @id @default(cuid())
  eventId   String
  classId   String?
  courtNum  Int
  round     Int
  status         String   @default("pending")
  rankingMode    String   @default("ranked")
  scoreConfirmed Boolean  @default(false)
  eloChange      Float    @default(0)

  // Competition metadata
  groupLabel     String?
  bracketStage   String?
  bracketPosition Int?
  matchFormat    String?
  sessionId      String?  // which session this match is scheduled in
  isCrossClub    Boolean  @default(false) // players from different clubs

  createdAt DateTime @default(now())

  event   Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class   EventClass?   @relation(fields: [classId], references: [id], onDelete: Cascade)
  players MatchPlayer[]
}

model CompetitionResult {
  id               String @id @default(cuid())
  eventId          String
  classId          String
  playerId         String
  pairId           String?

  // Group stage results
  groupLabel       String?
  groupPosition    Int?     // 1st, 2nd, 3rd in group
  groupWins        Int      @default(0)
  groupLosses      Int      @default(0)
  groupPointDiff   Int      @default(0)

  // Elimination results
  bracketLevel     String?  // "upper" | "lower"
  bracketReached   String?  // "r16", "qf", "sf", "f", "winner"
  finalPlacement   Int?     // 1st, 2nd, 3rd, etc.

  createdAt        DateTime @default(now())

  @@unique([eventId, classId, playerId])
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  team     Int    // 1 or 2
  score    Int    @default(0)

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
}

model WhatsAppGroup {
  id        String   @id @default(cuid())
  name      String   // e.g. "Tuesday Crew", "Mixed Doubles"
  createdAt DateTime @default(now())

  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])

  events EventWhatsAppGroup[]
}

model EventWhatsAppGroup {
  id             String @id @default(cuid())
  eventId        String
  whatsappGroupId String

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  whatsappGroup WhatsAppGroup @relation(fields: [whatsappGroupId], references: [id], onDelete: Cascade)

  @@unique([eventId, whatsappGroupId])
}

model ClubPost {
  id        String   @id @default(cuid())
  clubId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  club     Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author   Player        @relation(fields: [authorId], references: [id])
  comments ClubComment[]
}

model ClubComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   ClubPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author Player   @relation(fields: [authorId], references: [id])
}
