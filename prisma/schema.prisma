generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Player {
  id           String   @id @default(cuid())
  name         String
  emoji        String   @default("🏓")
  rating       Float    @default(1000)  // legacy, kept for backwards compat
  wins         Int      @default(0)
  losses       Int      @default(0)
  createdAt    DateTime @default(now())

  // Global rating (from cross-club matches)
  globalRating           Float?   // null = not yet established
  globalRatingConfidence Int      @default(0) // 0=none, 1-3=estimated, 4+=direct
  globalWins             Int      @default(0)
  globalLosses           Int      @default(0)

  // DUPR
  duprId       String?  // DUPR player ID
  duprRating   Float?   // synced from DUPR

  // Auth
  email        String?  @unique
  passwordHash String?
  role         String   @default("user") // "admin" | "user"
  status       String   @default("active") // "active" | "voided"
  inviteToken  String?  @unique // for claim-account flow
  resetToken   String?  @unique // for password reset flow

  // Profile
  gender       String?  // "M" | "F"
  phone        String?  // WhatsApp number
  photoUrl     String?

  eventPlayers  EventPlayer[]
  matchPlayers  MatchPlayer[]
  createdEvents Event[]       @relation("createdEvents")
  eventHelpers  EventHelper[]
  pairsAsPlayer1 EventPair[]  @relation("pairPlayer1")
  pairsAsPlayer2 EventPair[]  @relation("pairPlayer2")
  pairLocksAsA   EventPairLock[] @relation("pairLockA")
  pairLocksAsB   EventPairLock[] @relation("pairLockB")
  clubMembers   ClubMember[]
  clubRatings   ClubPlayerRating[]
  createdClubs  Club[]        @relation("createdClubs")
  clubInvites      ClubInvite[]      @relation("ClubInviteCreator")
  clubJoinRequests ClubJoinRequest[]
  clubPosts     ClubPost[]
  clubComments  ClubComment[]
  scoredMatches Match[]       @relation("matchScorer")
  leagueTeamPlayers LeagueTeamPlayer[]
  leagueCaptain     LeagueTeam[]       @relation("teamCaptain")
  leagueViceCaptain LeagueTeam[]       @relation("teamViceCaptain")
  createdLeagues    League[]           @relation("leagueCreator")
  deputyLeagues     League[]           @relation("leagueDeputy")
  leagueHelpers     LeagueHelper[]
}

model Club {
  id          String   @id @default(cuid())
  name        String
  emoji       String   @default("🏟️")
  logoUrl     String?
  coverUrl    String?
  description String?
  city        String?
  country     String?
  status      String   @default("active") // "draft" | "active" | "closed"
  ratingOffset Float?  // club rating - global rating offset (calculated)
  ratingBridgePlayers Int @default(0) // how many players have global ratings
  createdAt   DateTime @default(now())

  createdById String?
  createdBy   Player?  @relation("createdClubs", fields: [createdById], references: [id])

  members        ClubMember[]
  playerRatings  ClubPlayerRating[]
  events         Event[]
  whatsappGroups WhatsAppGroup[]
  posts          ClubPost[]
  locations      ClubLocation[]
  invites        ClubInvite[]
  joinRequests   ClubJoinRequest[]
  leagueTeams    LeagueTeam[]
  leagues        League[]         @relation("clubLeagues")
}

model ClubPlayerRating {
  id       String @id @default(cuid())
  clubId   String
  playerId String
  rating   Float  @default(1000)
  wins     Int    @default(0)
  losses   Int    @default(0)

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId])
}

model ClubLocation {
  id            String @id @default(cuid())
  clubId        String
  name          String
  googleMapsUrl String?
  city          String?
  country       String?
  /// Number of courts available at this location. Used as the default (and
  /// cap) for events created at this location.
  numCourts     Int    @default(2)

  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  events Event[]
}

model ClubMember {
  id       String @id @default(cuid())
  clubId   String
  playerId String
  role     String @default("member") // "owner" | "admin" | "member"

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId])
  @@index([playerId])
}

model ClubJoinRequest {
  id        String   @id @default(cuid())
  clubId    String
  playerId  String
  message   String?
  status    String   @default("pending") // "pending" | "accepted" | "declined"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId])
}

model ClubInvite {
  id        String   @id @default(cuid())
  clubId    String
  token     String   @unique @default(cuid())
  createdBy String
  expiresAt DateTime?
  usedCount Int      @default(0)
  maxUses   Int?     // null = unlimited
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  club    Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator Player @relation("ClubInviteCreator", fields: [createdBy], references: [id])
}

model Event {
  id           String   @id @default(cuid())
  name         String
  date         DateTime @default(now())
  endDate      DateTime?
  status       String   @default("draft") // draft, visible, open, closed, active, completed
  numCourts    Int      @default(2)
  openSignup   Boolean  @default(true)  // kept for backwards compat
  visibility   String   @default("visible") // kept for backwards compat

  // Speaker host
  speakerUserId   String?  // player ID of the device acting as speaker
  speakerUserName String?  // display name
  pendingAnnouncement String? // text to speak, cleared after played

  createdAt    DateTime @default(now())

  createdById  String?
  createdBy    Player?  @relation("createdEvents", fields: [createdById], references: [id])

  clubId       String?
  club         Club?    @relation(fields: [clubId], references: [id])
  locationId   String?
  location     ClubLocation? @relation(fields: [locationId], references: [id])

  // Multi-week competition: sessions link to parent
  parentEventId String?
  parentEvent   Event?   @relation("eventSessions", fields: [parentEventId], references: [id])
  sessions      Event[]  @relation("eventSessions")

  classes        EventClass[]
  players        EventPlayer[]
  pairs          EventPair[]
  pairLocks      EventPairLock[]
  matches        Match[]
  helpers        EventHelper[]
  whatsappGroups EventWhatsAppGroup[]
  leagueMatchDay LeagueMatchDay?

  @@index([clubId])
  @@index([status])
  @@index([date])
}

model EventClass {
  id          String @id @default(cuid())
  eventId     String
  name        String @default("Open")
  isDefault   Boolean @default(true) // the auto-created class

  // Dimensions
  format      String  @default("doubles") // doubles, singles
  gender      String  @default("open")    // male, female, mix, open
  ageGroup    String  @default("open")    // open, 18+, 50+, 60+, custom
  ageMin      Int?
  ageMax      Int?
  skillMin    Float?  // DUPR min (e.g. 3.5)
  skillMax    Float?  // DUPR max (e.g. 4.0)

  // Format settings
  scoringFormat String  @default("1x11") // e.g. "1x11", "3x11", "1xR15", "3xR21"
  winBy         String  @default("2") // "1", "2", "cap13", "cap15", "cap17", "cap18", "cap23", "cap25"
  timedMinutes  Int?
  pairingMode  String   @default("random")
  /// New unified pairing settings (v2 model). JSON shape matches
  /// PairingSettings from src/lib/solver/types.ts. When present, the solver
  /// uses this instead of the legacy pairingMode + prio* booleans.
  pairingSettings Json?
  playMode     String   @default("round_based") // "round_based" | "continuous"
  prioSpeed    Boolean  @default(true)
  prioFairness Boolean  @default(true)
  prioSkill    Boolean  @default(false)
  prioVariety  Boolean  @default(false)
  rankingMode  String   @default("ranked")
  minPlayers   Int?
  maxPlayers   Int?

  // Below-min action
  belowMinAction    String?  // "cancel" | "merge" | "tbd"
  mergeWithClassId  String?  // class to merge with if belowMinAction = "merge"

  // Cross-class elimination merge
  upperBracketMergeClassId  String?  // merge upper bracket with this class's lower bracket
  lowerBracketMergeClassId  String?  // merge lower bracket with this class's upper bracket

  // Competition
  competitionMode   String?  // null | "groups_elimination"
  competitionConfig Json?
  competitionPhase  String?  // "groups" | "bracket_upper" | "bracket_lower" | "completed"

  event    Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  players  EventPlayer[]
  pairs    EventPair[]
  pairLocks EventPairLock[]
  matches  Match[]

  @@index([eventId])
}

model Notification {
  id        String   @id @default(cuid())
  playerId  String
  type      String   // "pair_request" | "pair_accepted" | "match_ready" | "event_invite"
  title     String
  body      String?
  linkUrl   String?  // where to navigate when tapped
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PairRequest {
  id          String   @id @default(cuid())
  eventId     String
  classId     String
  requesterId String   // who asked
  requestedId String   // who they asked
  status      String   @default("pending") // "pending" | "accepted" | "declined" | "cancelled"
  createdAt   DateTime @default(now())

  @@unique([eventId, classId, requesterId])
}

model EventPlayer {
  id              String   @id @default(cuid())
  eventId         String
  classId         String?
  playerId        String
  status          String   @default("registered")
  /// Effective skill level used by the solver. L1–L5. Equals autoSkillLevel
  /// unless an admin has overridden it. See src/lib/solver/skillAssign.ts.
  skillLevel      Int?
  /// Auto-assigned skill level from DUPR/rating at the time of add or
  /// last recalculate. Preserved across overrides so admins can see the gap.
  autoSkillLevel  Int?
  joinedAt        DateTime @default(now())

  event  Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class  EventClass? @relation(fields: [classId], references: [id], onDelete: Cascade)
  player Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId, classId])
  @@index([playerId])
}

/// Manual pair lock — two players who MUST partner on every round they
/// play. Used for tournament practice pairs, mentor-mentee, family etc.
model EventPairLock {
  id         String   @id @default(cuid())
  eventId    String
  classId    String?
  playerAId  String
  playerBId  String
  note       String?  // optional reason, e.g. "practicing for tournament"
  createdAt  DateTime @default(now())

  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class     EventClass? @relation(fields: [classId], references: [id], onDelete: Cascade)
  playerA   Player      @relation("pairLockA", fields: [playerAId], references: [id], onDelete: Cascade)
  playerB   Player      @relation("pairLockB", fields: [playerBId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerAId, playerBId])
  @@index([eventId])
}

model EventPair {
  id        String @id @default(cuid())
  eventId   String
  classId   String?
  player1Id String
  player2Id String
  groupLabel String?
  seed       Int?

  event   Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class   EventClass? @relation(fields: [classId], references: [id], onDelete: Cascade)
  player1 Player      @relation("pairPlayer1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2 Player      @relation("pairPlayer2", fields: [player2Id], references: [id], onDelete: Cascade)

  @@unique([eventId, player1Id, player2Id])
}

model EventHelper {
  id       String @id @default(cuid())
  eventId  String
  playerId String

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

model Match {
  id        String   @id @default(cuid())
  eventId   String
  classId   String?
  courtNum  Int
  round     Int
  status         String   @default("pending")
  rankingMode    String   @default("ranked")
  scoreConfirmed Boolean  @default(false)
  team1Confirmed Boolean  @default(false)
  team2Confirmed Boolean  @default(false)
  confirmedById  String?  // who did final/manager confirmation
  eloChange      Float    @default(0)

  // Competition metadata
  groupLabel     String?
  bracketStage   String?
  bracketPosition Int?
  matchFormat    String?
  sessionId      String?  // which session this match is scheduled in
  isCrossClub    Boolean  @default(false) // players from different clubs
  scorerId       String?  // player assigned as scorer/judge

  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  event   Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  class   EventClass?   @relation(fields: [classId], references: [id], onDelete: Cascade)
  scorer  Player?       @relation("matchScorer", fields: [scorerId], references: [id])
  players MatchPlayer[]
  leagueGame LeagueGame?

  @@index([eventId])
  @@index([status])
}

model CompetitionResult {
  id               String @id @default(cuid())
  eventId          String
  classId          String
  playerId         String
  pairId           String?

  // Group stage results
  groupLabel       String?
  groupPosition    Int?     // 1st, 2nd, 3rd in group
  groupWins        Int      @default(0)
  groupLosses      Int      @default(0)
  groupPointDiff   Int      @default(0)

  // Elimination results
  bracketLevel     String?  // "upper" | "lower"
  bracketReached   String?  // "r16", "qf", "sf", "f", "winner"
  finalPlacement   Int?     // 1st, 2nd, 3rd, etc.

  createdAt        DateTime @default(now())

  @@unique([eventId, classId, playerId])
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  team     Int    // 1 or 2
  score    Int    @default(0)

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([playerId])
}

model WhatsAppGroup {
  id        String   @id @default(cuid())
  name      String   // e.g. "Tuesday Crew", "Mixed Doubles"
  createdAt DateTime @default(now())

  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])

  events EventWhatsAppGroup[]
}

model EventWhatsAppGroup {
  id             String @id @default(cuid())
  eventId        String
  whatsappGroupId String

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  whatsappGroup WhatsAppGroup @relation(fields: [whatsappGroupId], references: [id], onDelete: Cascade)

  @@unique([eventId, whatsappGroupId])
}

model ClubPost {
  id        String   @id @default(cuid())
  clubId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  club     Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author   Player        @relation(fields: [authorId], references: [id])
  comments ClubComment[]
}

model ClubComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   ClubPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author Player   @relation(fields: [authorId], references: [id])
}

// ── League / Season ──

model League {
  id          String   @id @default(cuid())
  name        String
  description String?
  season      String?  // "2025", "Spring 2026"
  status      String   @default("draft") // draft, active, completed
  config      Json?    // { maxRoster, bestOfN, maxPointsPerMatchDay, scoringRules }
  clubId      String?  // Organizing club (required at creation; optional for legacy rows)
  createdById String?  // League Director
  deputyId    String?  // Deputy Director
  createdAt   DateTime @default(now())

  club       Club?            @relation("clubLeagues", fields: [clubId], references: [id])
  createdBy  Player?          @relation("leagueCreator", fields: [createdById], references: [id])
  deputy     Player?          @relation("leagueDeputy", fields: [deputyId], references: [id])
  teams      LeagueTeam[]
  rounds     LeagueRound[]
  categories LeagueCategory[]
  helpers    LeagueHelper[]

  @@index([clubId])
}

model LeagueHelper {
  id       String @id @default(cuid())
  leagueId String
  playerId String

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([leagueId, playerId])
}

model LeagueTeam {
  id            String  @id @default(cuid())
  leagueId      String
  clubId        String? // optional link to Club
  name          String
  slogan        String?
  logoUrl       String?
  photoUrl      String? // team group photo
  captainId     String? // "Team Leader"
  viceCaptainId String? // "Deputy"

  league      League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  club        Club?    @relation(fields: [clubId], references: [id])
  captain     Player?  @relation("teamCaptain", fields: [captainId], references: [id])
  viceCaptain Player?  @relation("teamViceCaptain", fields: [viceCaptainId], references: [id])
  players     LeagueTeamPlayer[]
  matchDayTeams LeagueMatchDayTeam[]
  gamesAsTeam1  LeagueGame[] @relation("gameTeam1")
  gamesAsTeam2  LeagueGame[] @relation("gameTeam2")
  gamesWon      LeagueGame[] @relation("gameWinner")
}

model LeagueTeamPlayer {
  id       String   @id @default(cuid())
  teamId   String
  playerId String
  joinedAt DateTime @default(now())

  team   LeagueTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player     @relation(fields: [playerId], references: [id])
  @@unique([teamId, playerId])
}

model LeagueCategory {
  id            String @id @default(cuid())
  leagueId      String
  name          String  // "Men's Doubles", "Women's Doubles", "Mixed Doubles", "Singles"
  format        String  @default("doubles") // "doubles" or "singles"
  gender        String  @default("open")    // "male", "female", "mix", "open"
  ageGroup      String  @default("open")    // "open", "18+", "35+", "50+", "55+", "60+", "65+", "70+"
  skillMin      Float?  // DUPR min (e.g. 3.0)
  skillMax      Float?  // DUPR max (e.g. 4.0)
  scoringFormat String  @default("3x11")    // e.g. "1x11", "3x11", "1xR15"
  winBy         String  @default("2")
  status        String  @default("active") // "draft" | "active"
  sortOrder     Int     @default(0)

  league League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  games  LeagueGame[]
}

model LeagueRound {
  id          String    @id @default(cuid())
  leagueId    String
  roundNumber Int
  name        String?   // "Jornada 1", "Grande Final"
  suggestedDate DateTime?
  status      String    @default("scheduled") // scheduled, in_progress, completed

  league    League           @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  matchDays LeagueMatchDay[]
}

model LeagueMatchDay {
  id         String    @id @default(cuid())
  roundId    String
  eventId    String?   @unique // link to Event for actual scoring
  date       DateTime?
  status     String    @default("scheduled") // scheduled, in_progress, completed
  hostTeamId String?

  round  LeagueRound          @relation(fields: [roundId], references: [id], onDelete: Cascade)
  event  Event?               @relation(fields: [eventId], references: [id])
  teams  LeagueMatchDayTeam[]
  games  LeagueGame[]
}

model LeagueMatchDayTeam {
  id         String @id @default(cuid())
  matchDayId String
  teamId     String
  points     Int    @default(0) // cached team points for this match day

  matchDay LeagueMatchDay @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  team     LeagueTeam     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  @@unique([matchDayId, teamId])
}

model LeagueGame {
  id         String  @id @default(cuid())
  matchDayId String
  categoryId String
  matchId    String? @unique // link to existing Match for scoring
  team1Id    String
  team2Id    String
  winnerId   String? // set when match completes

  matchDay LeagueMatchDay @relation(fields: [matchDayId], references: [id], onDelete: Cascade)
  category LeagueCategory @relation(fields: [categoryId], references: [id])
  match    Match?         @relation(fields: [matchId], references: [id])
  team1    LeagueTeam     @relation("gameTeam1", fields: [team1Id], references: [id])
  team2    LeagueTeam     @relation("gameTeam2", fields: [team2Id], references: [id])
  winner   LeagueTeam?    @relation("gameWinner", fields: [winnerId], references: [id])
}
