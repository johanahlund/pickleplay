generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Player {
  id           String   @id @default(cuid())
  name         String
  emoji        String   @default("🏓")
  rating       Float    @default(1000)
  wins         Int      @default(0)
  losses       Int      @default(0)
  createdAt    DateTime @default(now())

  // Auth
  email        String?  @unique
  passwordHash String?
  role         String   @default("user") // "admin" | "user"
  status       String   @default("active") // "active" | "voided"
  inviteToken  String?  @unique // for claim-account flow
  resetToken   String?  @unique // for password reset flow

  // Profile
  gender       String?  // "M" | "F"
  phone        String?  // WhatsApp number
  photoUrl     String?

  eventPlayers  EventPlayer[]
  matchPlayers  MatchPlayer[]
  createdEvents Event[]       @relation("createdEvents")
  eventHelpers  EventHelper[]
  pairsAsPlayer1 EventPair[]  @relation("pairPlayer1")
  pairsAsPlayer2 EventPair[]  @relation("pairPlayer2")
  clubMembers   ClubMember[]
  createdClubs  Club[]        @relation("createdClubs")
  clubPosts     ClubPost[]
  clubComments  ClubComment[]
}

model Club {
  id          String   @id @default(cuid())
  name        String
  emoji       String   @default("🏓")
  description String?
  createdAt   DateTime @default(now())

  createdById String?
  createdBy   Player?  @relation("createdClubs", fields: [createdById], references: [id])

  members        ClubMember[]
  events         Event[]
  whatsappGroups WhatsAppGroup[]
  posts          ClubPost[]
  locations      ClubLocation[]
}

model ClubLocation {
  id            String @id @default(cuid())
  clubId        String
  name          String
  googleMapsUrl String?

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

model ClubMember {
  id       String @id @default(cuid())
  clubId   String
  playerId String
  role     String @default("member") // "owner" | "admin" | "member"

  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([clubId, playerId])
}

model Event {
  id           String   @id @default(cuid())
  name         String
  date         DateTime @default(now())
  endDate      DateTime?
  status       String   @default("setup") // setup, active, completed
  numCourts    Int      @default(2)
  format       String   @default("doubles") // doubles, singles
  numSets      Int      @default(1) // 1, 2, or 3
  scoringType  String   @default("normal_11") // normal_11, normal_15, rally_21, timed
  timedMinutes Int?     // only when scoringType = "timed"
  pairingMode  String   @default("random") // random, skill_balanced, mixed_gender, skill_mixed_gender, king_of_court, swiss
  rankingMode  String   @default("ranked") // "ranked" | "approval" | "none"
  minPlayers   Int?     // minimum players needed
  maxPlayers   Int?     // maximum players allowed (null = unlimited)
  openSignup   Boolean  @default(true)  // true = anyone can join, false = only manager can add players
  visibility   String   @default("visible") // "visible" | "hidden" (hidden only shown to owner/helpers/players)

  // Competition config (null = normal event)
  competitionMode String?  // null | "groups_elimination"
  competitionConfig Json?  // stores full competition settings as JSON
  competitionPhase  String? // "groups" | "bracket_upper" | "bracket_lower" | "completed"

  createdAt    DateTime @default(now())

  createdById  String?
  createdBy    Player?  @relation("createdEvents", fields: [createdById], references: [id])

  clubId       String?
  club         Club?    @relation(fields: [clubId], references: [id])

  players        EventPlayer[]
  matches        Match[]
  helpers        EventHelper[]
  pairs          EventPair[]
  whatsappGroups EventWhatsAppGroup[]
}

model EventPlayer {
  id         String   @id @default(cuid())
  eventId    String
  playerId   String
  status     String   @default("registered") // "registered" | "waitlisted" | "checked_in" | "paused"
  skillLevel Int?     // 1 = beginner, 2 = intermediate, 3 = advanced (per-event)
  joinedAt   DateTime @default(now())

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

model EventPair {
  id        String @id @default(cuid())
  eventId   String
  player1Id String
  player2Id String
  groupLabel String? // "A", "B", "C" etc — for competition group assignment
  seed       Int?    // seeding position within group

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player1 Player @relation("pairPlayer1", fields: [player1Id], references: [id], onDelete: Cascade)
  player2 Player @relation("pairPlayer2", fields: [player2Id], references: [id], onDelete: Cascade)

  @@unique([eventId, player1Id, player2Id])
}

model EventHelper {
  id       String @id @default(cuid())
  eventId  String
  playerId String

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
}

model Match {
  id        String   @id @default(cuid())
  eventId   String
  courtNum  Int
  round     Int
  status         String   @default("pending") // pending, active, completed
  rankingMode    String   @default("ranked") // "ranked" | "approval" | "none"
  scoreConfirmed Boolean  @default(false)    // for approval mode: true once confirmed
  eloChange      Float    @default(0) // stored for score edit reversal

  // Competition metadata
  groupLabel     String?  // "A", "B" etc — which group this match belongs to
  bracketStage   String?  // "upper_qf", "upper_sf", "upper_f", "upper_3rd", "lower_qf", etc.
  bracketPosition Int?    // position within bracket stage (1, 2, 3...)
  matchFormat    String?  // override format for this specific match (e.g. "bo3_11")

  createdAt DateTime @default(now())

  event   Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  players MatchPlayer[]
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  team     Int    // 1 or 2
  score    Int    @default(0)

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
}

model WhatsAppGroup {
  id        String   @id @default(cuid())
  name      String   // e.g. "Tuesday Crew", "Mixed Doubles"
  createdAt DateTime @default(now())

  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])

  events EventWhatsAppGroup[]
}

model EventWhatsAppGroup {
  id             String @id @default(cuid())
  eventId        String
  whatsappGroupId String

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  whatsappGroup WhatsAppGroup @relation(fields: [whatsappGroupId], references: [id], onDelete: Cascade)

  @@unique([eventId, whatsappGroupId])
}

model ClubPost {
  id        String   @id @default(cuid())
  clubId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  club     Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author   Player        @relation(fields: [authorId], references: [id])
  comments ClubComment[]
}

model ClubComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   ClubPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author Player   @relation(fields: [authorId], references: [id])
}
